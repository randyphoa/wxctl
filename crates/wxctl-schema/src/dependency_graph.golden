## bridges (2)
database_access: orchestrate_connection -> common_core_connection when=always
  constraint common_core_connection.datasource_type in [postgresql, mysql, oracle, db2, netezza]
  constraint orchestrate_connection.connection_type in [key_value_creds]
  map credentials.database -> properties.database
  map credentials.host -> properties.host
  map credentials.password -> properties.password
  map credentials.port -> properties.port
  map credentials.username -> properties.username
object_storage_access: orchestrate_connection -> common_core_connection when=always
  constraint common_core_connection.datasource_type in [s3, cos, azure]
  constraint orchestrate_connection.connection_type in [key_value_creds]
  map credentials.access_key -> properties.access_key
  map credentials.bucket -> properties.bucket
  map credentials.secret_key -> properties.secret_key
  map credentials.url -> properties.url
